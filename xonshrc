"""
def intensity_fg_old(fraction, low = 0, high = 1, reverse = False):
	fraction = (fraction - low) / (high - low)
	hue = fraction * 240 if reverse else 240 - fraction * 240
	r,g,b = hpluv_to_rgb((hue, 100, 40 if $LIGHT_MODE else 76))
