def sys_stats(*, temp: float = None, temp_low = temp_low, temp_high = temp_high) -> str:
	'stats about the system, excluding the environment'
	venv_str = f"({$VIRTUAL_ENV.split('/')[-1]}) | " if 'VIRTUAL_ENV' in ${...} else ''
	LAV_str = ' '.join(intensity_fg(load/core_count) + str(round(load, 1)) for load in os.getloadavg()) + reset

	with open(f"/etc/os-release") as f:
		os_stats = dict((line[:-1]).split('=', 1) for line in f.readlines())
	os_str = '\x1b[' + os_stats['ANSI_COLOR'][1:-1] + 'm' + os_stats['PRETTY_NAME'][1:-1] + reset

	with open('/proc/sys/kernel/osrelease') as file:
		kernel_str = file.readline()[:-1]

	if temp is None:
		with open(f"{find_hwmon('acpitz')}/temp1_input") as file:
			acpitz = int(file.readline())/1000
	else:
		acpitz = temp
	acpitz_str = f"{intensity_fg(acpitz, temp_low, temp_high)}{round(acpitz)}°C{reset}"


	# window size
	fd = sys.stdin.fileno()
	old = termios.tcgetattr(fd)
	try:
	    tty.setraw(fd)
	    # ask for window pixel size
	    sys.stdout.write("\033[14t")
	    sys.stdout.flush()
	    buf = ""
	    while not buf.endswith("t"):
	        buf += sys.stdin.read(1)
	finally:
	    termios.tcsetattr(fd, termios.TCSADRAIN, old)
	# buf should look like: ESC[4;height;widtht
	m = re.match(r"\x1b\[4;(\d+);(\d+)t", buf)
	if not m:
		raise RuntimeError(f"unexpected reply: {repr(buf)}")
	window_y, window_x = map(int, m.groups())
	window_str = f'{window_x}x{window_y}'

	#wmm, hmm = _resolution_getter.winfo_screenmmwidth(), _resolution_getter.winfo_screenmmheight()
	
	return f"{acpitz_str} {LAV_str} {os_str} {kernel_str}"

