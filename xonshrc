	mem = psutil._pslinux.svmem(*(entry/1024/1024 for entry in psutil.virtual_memory()))
	swap = psutil._common.sswap(*(entry/1024/1024 for entry in psutil.swap_memory()))

	mem_private = mem.total - mem.available
	mem_public = mem.available - mem.free
	swap_used = swap.total - swap.free

	mem_str = f"{intensity_fg(mem_private, 0, mem.total)}({round(mem_private)}+{round(mem_public)})/{round(mem.total)}"
	swap_str = f"{intensity_fg(swap_used, 0, swap.total)}{round(swap_used)}/{round(swap.total)}"

	return f"{mem_str} MiB{reset} + {swap_str} MiB{reset}"
	
