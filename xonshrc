def find_hwmon(name: str) -> str:
	'return path to hwmon device with matching name'
	for d in os.listdir("/sys/class/hwmon"):
		p = f"/sys/class/hwmon/{d}/name"
		try:
			with open(p) as f:
				if f.read().strip() == name:
					return f"/sys/class/hwmon/{d}"
		except FileNotFoundError:
			pass
	raise FileNotFoundError(f"no hwmon named {name!r}")

_ANSI = re.compile(r'\x1b\[[0-9;]*[mGKHF]')
def visible_width(text):
    return wcwidth.wcswidth(_ANSI.sub('', text))

def justify_visible(size: int, *args):
	return args[0] + ' '*(size - visible_width(args[0]) - visible_width(args[1])) + args[1]

def pretty_pwd(length: int, pad: bool = True) -> str:
	pwd = $PWD + ('' if $PWD == '/' else '/')
	pwd_len = len(pwd) 
	if pwd_len > length:
		pwd = '…' + pwd[1-length:]
		pwd_len = length
	pwd_pad_amount = length - pwd_len
	pwd_left_pad_amount = pwd_pad_amount//2
	pwd_right_pad_amount = pwd_pad_amount - pwd_left_pad_amount
	
	dirs = str()
	for index, dir in enumerate(pwd.split('/')[:-1]):
		dirs += f"{fg_hues[index % 6]}{dir}/"

	pwd_left_pad = (fg_color['brblack'] + ('─'*length + ' ')[-pwd_left_pad_amount:]) if pwd_left_pad_amount != 0 else ''
	pwd_right_pad = fg_color['brblack'] + (' ' + '─'*length)[:pwd_right_pad_amount]

	if pad:
		return f"{pwd_left_pad}{dirs}{pwd_right_pad}{reset}"
	else:
		return dirs + reset

