def dir_stats() -> str:
	
	dirs = []
	files = []
	others = []

	for entry in os.scandir():
		if entry.is_dir():
			dirs.append('\x1b[34m' + entry.name)
		elif entry.is_file():
			files.append('\x1b[32m' + entry.name)
		else:
			others.append('\x1b[31m' + entry.name)
			
	pwd = pretty_pwd(length = 999, pad = False)

	return f'{pwd} {separator} 🗀 {len(dirs)}, 🗎 {len(files)}, ? {len(others)}'

