	pwd_str = pretty_pwd(os.get_terminal_size()[0] - 30)
	
	color = fg_color['red'] if cmd_return != 0 else fg_color['white'] 
	
	return f"{color}{time_str} {separator} {color}{prompt_count_str} {pwd_str} {color}{str_cmd_return} {separator} {color}{cmd_time_str}\n{reset_colour}{sm.ansi.stylise('>>> ', ('intensity', 'bold'))}"

def window_size() -> str:
	fd = sys.stdin.fileno()
	old = termios.tcgetattr(fd)
	try:
	    tty.setraw(fd)
	    # ask for window pixel size
	    sys.stdout.write("\033[14t")
	    sys.stdout.flush()
	    buf = ""
	    while not buf.endswith("t"):
	        buf += sys.stdin.read(1)
	finally:
	    termios.tcsetattr(fd, termios.TCSADRAIN, old)
	
	# buf should look like: ESC[4;height;widtht
	m = re.match(r"\x1b\[4;(\d+);(\d+)t", buf)
	if not m:
		raise RuntimeError(f"unexpected reply: {repr(buf)}")
	
	window_y, window_x = map(int, m.groups())
	return window_x, window_y

