def my_prompt() -> str:
	'custom script for xonsh prompt'

	global prompt_count
	
	$TITLE = f"xonsh │ {$USER}@{$HOSTNAME} │ {$PWD}"
	
	prompt_count += 1
	
	cmd_return = getattr(__xonsh__.lastcmd, 'returncode', 0)
	str_cmd_return = str(cmd_return).rjust(3,'0')
	
