intensity_hues = [fg_color[hue] for hue in ['brblue', 'brcyan', 'brgreen', 'bryellow', 'brred']]
intensity_hues_reverse = list(reversed(intensity_hues))
def intensity_fg(fraction, low = 0, high = 1, reverse = False):
	fraction = (fraction - low) / (high - low)
	hue = int(fraction * 5) % 5	
	return intensity_hues_reverse[hue] if reverse else intensity_hues[hue]

def intensity_bar(fraction, low = 0, high = 1, fill:str='none', back:str='none', color=True, reverse_color=False):
	if not (low <= fraction <= high):
		raise ValueError("fraction must be in [low, high]")
	fraction = (fraction - low) / (high - low)
	index = round(min(max(fraction, 0.0), 1.0) * 8)
	if reverse_color:
		return f"{intensity_fg(fraction) if color else fg_color[fill]}{bg_color[back]}{' ▁▂▃▄▅▆▇█'[index]}"
	else:
		return f"{intensity_fg(fraction) if color else fg_color[fill]}{bg_color[back]}{' ▁▂▃▄▅▆▇█'[index]}"

_EIGHTH_LEFT = ' ▏▎▍▌▋▊▉█'
_EIGHTH_RIGHT = ' ▕🮇🮈▐🮉🮊🮋█'
_EIGHTH_LOWER = ' ▁▂▃▄▅▆▇█'
_EIGHTH_UPPER = ' ▔🮂🮃▀🮄🮅🮆█'

def progress_bar(
		fraction: int | float, 
		length: int = 1,
		fg: Literal['intensity'] | any = 'intensity', 
		bg: Literal['intensity'] | any = None,
		direction: Literal['up', 'down', 'left', 'right'] = 'right'
		) -> str:
	
	filled, remainder = divmod(fraction * length, 1)
	filled = int(filled)
	index = round(remainder * 8)

	if direction == 'right':
		result = _EIGHTH_LEFT[-1] * filled + ('' if index == 0 else _EIGHTH_LEFT[index])
		return result.ljust(length)
	elif direction == 'left':
		result = ('' if index == 0 else _EIGHTH_RIGHT[index]) + _EIGHTH_RIGHT[-1] * filled
		return result.rjust(length)
	elif direction == 'up':
		result = _EIGHTH_LOWER[-1] * filled + ('' if index == 0 else _EIGHTH_LOWER[index])
		return result.ljust(length)
	elif direction == 'down':
		result = _EIGHTH_UPPER[-1] * filled + ('' if index == 0 else _EIGHTH_UPPER[index])
		return result.ljust(length)
	else:
		raise ValueError("direction should be one of {'up', 'down', 'left', 'right'}")
