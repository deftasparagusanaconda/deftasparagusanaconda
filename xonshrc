	new = psutil.net_io_counters()
	delta = psutil._common.snetio(*(new - old for new, old in zip(new, net_io_counters_old)))
	net_io_counters_old = new

	rx = f"{delta.packets_recv}+{delta.dropin} {delta.bytes_recv}B ({delta.errin})"
